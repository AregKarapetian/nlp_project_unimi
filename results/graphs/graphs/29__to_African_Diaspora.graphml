<node id="one of them"/>
<node id="their fate"/>
<node id="greed and treachery"/>
<edge source="hermit" target="hermit" id="0">
  <data key="d0">roamed the dunes</data>
  <data key="d1">1</data>
</edge>
<edge source="hermit" target="hermit" id="1">
  <data key="d0">stumbled upon a cave</data>
  <data key="d1">2</data>
</edge>
<edge source="hermit" target="hermit" id="2">
  <data key="d0">saw a glint of gold</data>
  <data key="d1">3</data>
</edge>
<edge source="hermit" target="hermit" id="3">
  <data key="d0">fled with all haste</data>
  <data key="d1">4</data>
</edge>
<edge source="hermit" target="their fate" id="0">
  <data key="d0">was unaware of their fate</data>
  <data key="d1">12</data>
</edge>
<edge source="three rough men" target="three rough men" id="0">
  <data key="d0">lurked nearby preying on travelers</data>
  <data key="d1">5</data>
</edge>
<edge source="three men" target="hermit" id="0">
  <data key="d0">watched the hermit flee</data>
  <data key="d1">6</data>
</edge>
<edge source="three men" target="hermit" id="1">
  <data key="d0">asked the hermit to lead them</data>
  <data key="d1">7</data>
</edge>
<edge source="three men" target="his warning" id="0">
  <data key="d0">ignored his warning</data>
  <data key="d1">8</data>
</edge>
<edge source="three men" target="three men" id="0">
  <data key="d0">saw a pile of glittering metal</data>
  <data key="d1">9</data>
</edge>
<edge source="three men" target="three men" id="1">
  <data key="d0">began to discuss how to divide the treasure</data>
  <data key="d1">10</data>
</edge>
<edge source="one of them" target="one of them" id="0">
  <data key="d0">suggested sending one man to sell some gold and bring back supplies</data>
  <data key="d1">11</data>
</edge>
<edge source="greed and treachery" target="greed and treachery" id="0">
  <data key="d0">led them to a fate worse than death itself</data>
