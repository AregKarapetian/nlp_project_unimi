<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d1" for="edge" attr.name="order" attr.type="long"/>
<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="lion"/>
<node id="farmer"/>
<node id="oxen"/>
<node id="jackal"/>
<node id="deep voice"/>
<node id="farmer's wife"/>
<node id="dog"/>
<edge source="lion" target="farmer" id="0">
  <data key="d0">appeared before</data>
  <data key="d1">1</data>
</edge>
<edge source="lion" target="oxen" id="0">
  <data key="d0">demanded one of</data>
  <data key="d1">2</data>
</edge>
<edge source="lion" target="lion" id="0">
  <data key="d0">returned the next evening</data>
  <data key="d1">4</data>
</edge>
<edge source="farmer" target="farmer" id="0">
  <data key="d0">handed over an ox</data>
  <data key="d1">3</data>
</edge>
<edge source="farmer" target="farmer" id="1">
  <data key="d0">surrendered another ox</data>
  <data key="d1">5</data>
</edge>
<edge source="farmer" target="farmer" id="2">
  <data key="d0">declared the ram still intact</data>
  <data key="d1">13</data>
</edge>
<edge source="farmer" target="lion" id="0">
  <data key="d0">replied loudly and swung hatchet</data>
  <data key="d1">9</data>
</edge>
<edge source="jackal" target="farmer" id="0">
  <data key="d0">chanced upon the farmer</data>
  <data key="d1">6</data>
</edge>
<edge source="jackal" target="jackal" id="0">
  <data key="d0">outlined a clever ruse</data>
  <data key="d1">7</data>
</edge>
<edge source="jackal" target="jackal" id="1">
  <data key="d0">descended from the hill</data>
  <data key="d1">10</data>
</edge>
<edge source="deep voice" target="deep voice" id="0">
  <data key="d0">boomed from nearby hill</data>
  <data key="d1">8</data>
</edge>
<edge source="farmer's wife" target="farmer's wife" id="0">
  <data key="d0">packed a sheep into sack</data>
  <data key="d1">11</data>
</edge>
<edge source="dog" target="jackal" id="0">
  <data key="d0">sprang up and chased away</data>
