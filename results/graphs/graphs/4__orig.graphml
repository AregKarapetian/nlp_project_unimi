<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="bodhisatta"/>
<node id="hare"/>
<node id="vilva fruit"/>
<node id="another hare"/>
<node id="first hare"/>
<node id="second hare"/>
<node id="one hundred thousand hares"/>
