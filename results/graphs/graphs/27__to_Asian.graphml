<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d1" for="edge" attr.name="order" attr.type="long" />
  <key id="d0" for="edge" attr.name="relation" attr.type="string" />
  <graph edgedefault="directed">
    <node id="chonguita" />
    <node id="hsiang li" />
    <node id="chonguita's house" />
    <node id="their home" />
    <node id="chest" />
    <node id="villagers" />
    <node id="porch" />
    <edge source="chonguita" target="chonguita" id="0">
      <data key="d0">lived with family</data>
      <data key="d1">1</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="1">
      <data key="d0">decided to build new home</data>
      <data key="d1">4</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="2">
      <data key="d0">constructed a sturdy house</data>
      <data key="d1">5</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="3">
      <data key="d0">heard commotion outside</data>
      <data key="d1">6</data>
    </edge>
    <edge source="chonguita" target="chest" id="0">
      <data key="d0">hid hsiang li in chest</data>
      <data key="d1">8</data>
    </edge>
    <edge source="chonguita" target="hsiang li" id="0">
      <data key="d0">pretended to make tea for him</data>
      <data key="d1">9</data>
    </edge>
    <edge source="chonguita" target="hsiang li" id="1">
      <data key="d0">scalded hsiang li with hot water</data>
      <data key="d1">10</data>
    </edge>
    <edge source="chonguita" target="porch" id="0">
      <data key="d0">hung wolf's hide on porch</data>
      <data key="d1">12</data>
    </edge>
    <edge source="hsiang li" target="hsiang li" id="0">
      <data key="d0">disrupted their joy</data>
      <data key="d1">2</data>
    </edge>
    <edge source="hsiang li" target="chonguita's house" id="0">
      <data key="d0">raided chonguita's house</data>
      <data key="d1">3</data>
    </edge>
    <edge source="hsiang li" target="their home" id="0">
      <data key="d0">burst into their home</data>
      <data key="d1">7</data>
    </edge>
    <edge source="villagers" target="villagers" id="0">
      <data key="d0">gathered to celebrate victory</data>
      <data key="d1">11</data>
    </edge>
  </graph>
</graphml>
