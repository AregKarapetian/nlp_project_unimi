<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d1" for="edge" attr.name="order" attr.type="long" />
  <key id="d0" for="edge" attr.name="relation" attr.type="string" />
  <graph edgedefault="directed">
    <node id="crocodile" />
    <node id="mud" />
    <node id="traveler" />
    <node id="man" />
    <node id="man and the crocodile" />
    <node id="kumbuk tree" />
    <node id="gentle cow" />
    <node id="wise jackal" />
    <edge source="crocodile" target="crocodile" id="0">
      <data key="d0">made its lair</data>
      <data key="d1">1</data>
    </edge>
    <edge source="crocodile" target="crocodile" id="1">
      <data key="d0">turned treacherous</data>
      <data key="d1">6</data>
    </edge>
    <edge source="crocodile" target="man" id="0">
      <data key="d0">called out to the man</data>
      <data key="d1">4</data>
    </edge>
    <edge source="crocodile" target="man" id="1">
      <data key="d0">replied to the man</data>
      <data key="d1">8</data>
    </edge>
    <edge source="mud" target="mud" id="0">
      <data key="d0">dried and hardened</data>
      <data key="d1">2</data>
    </edge>
    <edge source="traveler" target="traveler" id="0">
      <data key="d0">passed by on his way</data>
      <data key="d1">3</data>
    </edge>
    <edge source="traveler" target="traveler" id="1">
      <data key="d0">broke open the hardened mud</data>
      <data key="d1">5</data>
    </edge>
    <edge source="man" target="crocodile" id="0">
      <data key="d0">asked the crocodile</data>
      <data key="d1">7</data>
    </edge>
    <edge source="man" target="man" id="0">
      <data key="d0">proposed a condition</data>
      <data key="d1">9</data>
    </edge>
    <edge source="man and the crocodile" target="man and the crocodile" id="0">
      <data key="d0">journeyed to gather testimony</data>
      <data key="d1">10</data>
    </edge>
    <edge source="kumbuk tree" target="man" id="0">
      <data key="d0">testified against the man</data>
      <data key="d1">11</data>
    </edge>
    <edge source="gentle cow" target="man" id="0">
      <data key="d0">testified against the man</data>
      <data key="d1">12</data>
    </edge>
    <edge source="wise jackal" target="wise jackal" id="0">
      <data key="d0">rendered its verdict</data>
      <data key="d1">13</data>
    </edge>
    <edge source="wise jackal" target="crocodile" id="0">
      <data key="d0">advised the traveler to strike down</data>
      <data key="d1">14</data>
    </edge>
  </graph>
</graphml>
