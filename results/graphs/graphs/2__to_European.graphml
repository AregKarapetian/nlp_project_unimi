<edge source="young herdsman" target="young herdsman" id="1">
  <data key="d0">declared he wanted to marry the she-dog</data>
  <data key="d1">8</data>
</edge>
<edge source="young herdsman" target="young herdsman" id="2">
  <data key="d0">caught hold of his wife and seized the dog skin</data>
