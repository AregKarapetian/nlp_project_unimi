<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d1" for="edge" attr.name="order" attr.type="long" />
  <key id="d0" for="edge" attr.name="relation" attr.type="string" />
  <graph edgedefault="directed">
    <node id="brer rabbit" />
    <node id="mr. hawk" />
    <node id="hawk" />
    <node id="jay-birds" />
    <node id="chonguita" />
    <edge source="brer rabbit" target="brer rabbit" id="0">
      <data key="d0">strolled along</data>
      <data key="d1">1</data>
    </edge>
    <edge source="brer rabbit" target="brer rabbit" id="1">
      <data key="d0">squirimed and struggled</data>
      <data key="d1">5</data>
    </edge>
    <edge source="brer rabbit" target="brer rabbit" id="2">
      <data key="d0">lay still</data>
      <data key="d1">7</data>
    </edge>
    <edge source="brer rabbit" target="brer rabbit" id="3">
      <data key="d0">slunk away</data>
      <data key="d1">14</data>
    </edge>
    <edge source="brer rabbit" target="mr. hawk" id="0">
      <data key="d0">hollered and begged</data>
      <data key="d1">6</data>
    </edge>
    <edge source="brer rabbit" target="jay-birds" id="0">
      <data key="d0">begged mr. hawk to spare the jay-birds</data>
      <data key="d1">9</data>
    </edge>
    <edge source="mr. hawk" target="mr. hawk" id="0">
      <data key="d0">soared overhead</data>
      <data key="d1">2</data>
    </edge>
    <edge source="mr. hawk" target="mr. hawk" id="1">
      <data key="d0">said he would catch some jay-birds</data>
      <data key="d1">8</data>
    </edge>
    <edge source="mr. hawk" target="brer rabbit" id="0">
      <data key="d0">held fast</data>
      <data key="d1">4</data>
    </edge>
    <edge source="mr. hawk" target="brer rabbit" id="1">
      <data key="d0">decided to release him instead</data>
      <data key="d1">10</data>
    </edge>
    <edge source="hawk" target="hawk" id="0">
      <data key="d0">flew closer</data>
      <data key="d1">3</data>
    </edge>
    <edge source="chonguita" target="brer rabbit" id="0">
      <data key="d0">chanced upon brer rabbit</data>
      <data key="d1">11</data>
    </edge>
    <edge source="chonguita" target="brer rabbit" id="1">
      <data key="d0">challenged him to a series of tests</data>
      <data key="d1">12</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="0">
      <data key="d0">emerged victorious in all three challenges</data>
      <data key="d1">13</data>
    </edge>
  </graph>
</graphml>
