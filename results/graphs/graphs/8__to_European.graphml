<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d1" for="edge" attr.name="order" attr.type="long"/>
<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="poor wight"/>
<node id="elves"/>
<node id="their laughter and music"/>
<node id="man"/>
<node id="neighbor"/>
<node id="envious neighbor"/>
<edge source="poor wight" target="poor wight" id="0">
  <data key="d0">found himself lost</data>
  <data key="d1">1</data>
</edge>
<edge source="poor wight" target="poor wight" id="1">
  <data key="d0">stumbled upon a hollow tree</data>
  <data key="d1">2</data>
</edge>
<edge source="elves" target="elves" id="0">
  <data key="d0">gathered at the base</data>
  <data key="d1">3</data>
</edge>
<edge source="elves" target="elves" id="1">
  <data key="d0">bid him farewell</data>
  <data key="d1">6</data>
</edge>
<edge source="elves" target="elves" id="2">
  <data key="d0">took a wen from his forehead</data>
  <data key="d1">7</data>
</edge>
<edge source="elves" target="elves" id="3">
  <data key="d0">restored the wen to his forehead</data>
  <data key="d1">11</data>
</edge>
<edge source="their laughter and music" target="their laughter and music" id="0">
  <data key="d0">echoed through the night</data>
  <data key="d1">4</data>
</edge>
<edge source="man" target="man" id="0">
  <data key="d0">laughed and sang with abandon</data>
  <data key="d1">5</data>
</edge>
<edge source="man" target="man" id="1">
  <data key="d0">returned to his village</data>
  <data key="d1">8</data>
</edge>
<edge source="neighbor" target="neighbor" id="0">
  <data key="d0">heard of the man's luck</data>
  <data key="d1">9</data>
</edge>
<edge source="envious neighbor" target="envious neighbor" id="0">
  <data key="d0">joined the elves' revelry</data>
  <data key="d1">10</data>
</edge>
<edge source="envious neighbor" target="envious neighbor" id="1">
  <data key="d0">returned home in tears</data>
  <data key="d1">12</data>
</edge>
</graph></graphml>