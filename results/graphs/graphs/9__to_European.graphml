<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d1" for="edge" attr.name="order" attr.type="long" />
  <key id="d0" for="edge" attr.name="relation" attr.type="string" />
  <graph edgedefault="directed">
    <node id="chonguita" />
    <node id="cape of good hope" />
    <node id="ship from batavia" />
    <node id="table bay" />
    <node id="captain van der meer" />
    <node id="ghostly vessel" />
    <node id="chonguita and captain van der meer" />
    <node id="treacherous waters" />
    <edge source="chonguita" target="cape of good hope" id="0">
      <data key="d0">lived in</data>
      <data key="d1">1</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="0">
      <data key="d0">grew into a skilled navigator</data>
      <data key="d1">4</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="1">
      <data key="d0">emerged victorious in the first challenge</data>
      <data key="d1">8</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="2">
      <data key="d0">emerged victorious again in the second challenge</data>
      <data key="d1">10</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="3">
      <data key="d0">emerged victorious for the third time</data>
      <data key="d1">12</data>
    </edge>
    <edge source="ship from batavia" target="table bay" id="0">
      <data key="d0">struggled to enter</data>
      <data key="d1">2</data>
    </edge>
    <edge source="captain van der meer" target="captain van der meer" id="0">
      <data key="d0">put out to sea</data>
      <data key="d1">3</data>
    </edge>
    <edge source="captain van der meer" target="captain van der meer" id="1">
      <data key="d0">challenged chonguita</data>
      <data key="d1">6</data>
    </edge>
    <edge source="captain van der meer" target="captain van der meer" id="2">
      <data key="d0">conceded defeat to chonguita</data>
      <data key="d1">13</data>
    </edge>
    <edge source="ghostly vessel" target="ghostly vessel" id="0">
      <data key="d0">appeared to ships in distress</data>
      <data key="d1">5</data>
    </edge>
    <edge source="ghostly vessel" target="ghostly vessel" id="1">
      <data key="d0">appeared less frequently</data>
      <data key="d1">14</data>
    </edge>
    <edge source="chonguita and captain van der meer" target="treacherous waters" id="0">
      <data key="d0">tried to outguess each other</data>
      <data key="d1">7</data>
    </edge>
    <edge source="chonguita and captain van der meer" target="chonguita and captain van der meer" id="0">
      <data key="d0">competed to create an effective sail</data>
      <data key="d1">9</data>
    </edge>
    <edge source="chonguita and captain van der meer" target="chonguita and captain van der meer" id="1">
      <data key="d0">competed to create a wall picture</data>
      <data key="d1">11</data>
    </edge>
  </graph>
