<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d1" for="edge" attr.name="order" attr.type="long" />
  <key id="d0" for="edge" attr.name="relation" attr.type="string" />
  <graph edgedefault="directed">
    <node id="sultan's daughter" />
    <node id="priest" />
    <node id="girl" />
    <node id="sultan" />
    <node id="ruthless slaves" />
    <node id="slaves" />
    <node id="traveler" />
    <node id="sultan's son" />
    <edge source="sultan's daughter" target="sultan's daughter" id="0">
      <data key="d0">was as lovely</data>
      <data key="d1">1</data>
    </edge>
    <edge source="priest" target="girl" id="0">
      <data key="d0">taught the koran</data>
      <data key="d1">2</data>
    </edge>
    <edge source="priest" target="girl" id="1">
      <data key="d0">coveted her virtue</data>
      <data key="d1">3</data>
    </edge>
    <edge source="priest" target="sultan" id="0">
      <data key="d0">sent a letter</data>
      <data key="d1">7</data>
    </edge>
    <edge source="girl" target="girl" id="0">
      <data key="d0">refused the advances</data>
      <data key="d1">5</data>
    </edge>
    <edge source="girl" target="girl" id="1">
      <data key="d0">removed the ladder</data>
      <data key="d1">6</data>
    </edge>
    <edge source="girl" target="girl" id="2">
      <data key="d0">crawled away and hid</data>
      <data key="d1">10</data>
    </edge>
    <edge source="girl" target="girl" id="3">
      <data key="d0">regained her legs</data>
      <data key="d1">14</data>
    </edge>
    <edge source="sultan" target="priest" id="0">
      <data key="d0">entrusted his daughter</data>
      <data key="d1">4</data>
    </edge>
    <edge source="sultan" target="ruthless slaves" id="0">
      <data key="d0">ordered her handed over</data>
      <data key="d1">8</data>
    </edge>
    <edge source="slaves" target="girl" id="0">
      <data key="d0">began to dig a grave</data>
      <data key="d1">9</data>
    </edge>
    <edge source="slaves" target="sultan" id="0">
      <data key="d0">brought gazelle blood</data>
      <data key="d1">11</data>
    </edge>
    <edge source="traveler" target="traveler" id="0">
      <data key="d0">spotted the girl sitting</data>
      <data key="d1">12</data>
    </edge>
    <edge source="sultan's son" target="sultan's son" id="0">
      <data key="d0">fell in love with her</data>
      <data key="d1">13</data>
    </edge>
  </graph>
</graphml>
