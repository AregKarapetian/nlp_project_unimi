<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d1" for="edge" attr.name="order" attr.type="long" />
  <key id="d0" for="edge" attr.name="relation" attr.type="string" />
  <graph edgedefault="directed">
    <node id="boy" />
    <node id="hlakanyana" />
    <node id="boys" />
    <node id="keepers" />
    <edge source="boy" target="hlakanyana" id="0">
      <data key="d0">is approached by</data>
      <data key="d1">1</data>
    </edge>
    <edge source="boy" target="hlakanyana" id="1">
      <data key="d0">hands over a tool</data>
      <data key="d1">7</data>
    </edge>
    <edge source="boy" target="boy" id="0">
      <data key="d0">emerges from the water first</data>
      <data key="d1">5</data>
    </edge>
    <edge source="hlakanyana" target="hlakanyana" id="0">
      <data key="d0">proposes a plan</data>
      <data key="d1">2</data>
    </edge>
    <edge source="hlakanyana" target="hlakanyana" id="1">
      <data key="d0">suggests taking a break</data>
      <data key="d1">3</data>
    </edge>
    <edge source="hlakanyana" target="hlakanyana" id="2">
      <data key="d0">proposes a challenge</data>
      <data key="d1">4</data>
    </edge>
    <edge source="hlakanyana" target="hlakanyana" id="3">
      <data key="d0">accuses the boy of cheating</data>
      <data key="d1">6</data>
    </edge>
    <edge source="hlakanyana" target="hlakanyana" id="4">
      <data key="d0">laughs at the potters' misfortune</data>
      <data key="d1">8</data>
    </edge>
    <edge source="hlakanyana" target="hlakanyana" id="5">
      <data key="d0">accepts a pot as compensation</data>
      <data key="d1">9</data>
    </edge>
    <edge source="hlakanyana" target="hlakanyana" id="6">
      <data key="d0">lends the pot to some boys</data>
      <data key="d1">10</data>
    </edge>
    <edge source="hlakanyana" target="hlakanyana" id="7">
      <data key="d0">accepts a goat as compensation</data>
      <data key="d1">12</data>
    </edge>
    <edge source="hlakanyana" target="hlakanyana" id="8">
      <data key="d0">lends the goat to some keepers</data>
      <data key="d1">13</data>
    </edge>
    <edge source="boys" target="boys" id="0">
      <data key="d0">shatters the pot</data>
      <data key="d1">11</data>
    </edge>
    <edge source="keepers" target="keepers" id="0">
      <data key="d0">kills the goat</data>
      <data key="d1">14</data>
    </edge>
  </graph>
</graphml>
