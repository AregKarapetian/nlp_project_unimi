<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d1" for="edge" attr.name="order" attr.type="long"/>
<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="farmer's wife"/>
<node id="crow"/>
<node id="her basket"/>
<node id="grain"/>
<node id="village elder"/>
<node id="snake"/>
<node id="mouse"/>
<node id="cat"/>
<edge source="farmer's wife" target="farmer's wife" id="0">
  <data key="d0">was busy winnowing corn</data>
  <data key="d1">1</data>
</edge>
<edge source="farmer's wife" target="crow" id="0">
  <data key="d0">flung a clod at the crow</data>
  <data key="d1">3</data>
</edge>
<edge source="crow" target="her basket" id="0">
  <data key="d0">snatched a grain from her basket</data>
  <data key="d1">2</data>
</edge>
<edge source="crow" target="crow" id="0">
  <data key="d0">promised to retrieve the grain</data>
  <data key="d1">5</data>
</edge>
<edge source="crow" target="crow" id="1">
  <data key="d0">found that the grain had rolled too far</data>
  <data key="d1">6</data>
</edge>
<edge source="crow" target="crow" id="2">
  <data key="d0">visited the king's palace but was refused</data>
  <data key="d1">8</data>
</edge>
<edge source="crow" target="crow" id="3">
  <data key="d0">encountered fire and water that refused to act</data>
  <data key="d1">10</data>
</edge>
<edge source="crow" target="village elder" id="0">
  <data key="d0">flew off to seek help from the village elder</data>
  <data key="d1">7</data>
</edge>
<edge source="crow" target="snake" id="0">
  <data key="d0">met a snake that refused to bite the queen</data>
  <data key="d1">9</data>
</edge>
<edge source="crow" target="mouse" id="0">
  <data key="d0">finally met a mouse too small to gnaw through the rope</data>
  <data key="d1">11</data>
</edge>
<edge source="grain" target="grain" id="0">
  <data key="d0">fell into a narrow crack</data>
  <data key="d1">4</data>
</edge>
<edge source="cat" target="mouse" id="0">
  <data key="d0">pounced on the mouse with lightning speed</data>
  <data key="d1">12</data>
</edge>
</graph></graphml>