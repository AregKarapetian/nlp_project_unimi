<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d1" for="edge" attr.name="order" attr.type="long"/>
<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="farmer"/>
<node id="lion"/>
<node id="jackal"/>
<edge source="farmer" target="farmer" id="0">
  <data key="d0">was terrified</data>
  <data key="d1">1</data>
</edge>
<edge source="farmer" target="farmer" id="1">
  <data key="d0">unhitched an oxen</data>
  <data key="d1">2</data>
</edge>
<edge source="farmer" target="farmer" id="2">
  <data key="d0">went home with an ox</data>
  <data key="d1">4</data>
</edge>
<edge source="farmer" target="farmer" id="3">
  <data key="d0">plowed again</data>
  <data key="d1">5</data>
</edge>
<edge source="farmer" target="farmer" id="4">
  <data key="d0">gave an ox to the lion</data>
  <data key="d1">7</data>
</edge>
<edge source="farmer" target="farmer" id="5">
  <data key="d0">drove a single ox home</data>
  <data key="d1">8</data>
</edge>
<edge source="farmer" target="farmer" id="6">
  <data key="d0">told the jackal about the lion</data>
  <data key="d1">10</data>
</edge>
<edge source="farmer" target="farmer" id="7">
  <data key="d0">agreed with the jackal</data>
  <data key="d1">12</data>
</edge>
<edge source="lion" target="lion" id="0">
  <data key="d0">took the oxen</data>
  <data key="d1">3</data>
</edge>
<edge source="lion" target="farmer" id="0">
  <data key="d0">came and said</data>
  <data key="d1">6</data>
</edge>
<edge source="jackal" target="farmer" id="0">
  <data key="d0">came by and asked</data>
  <data key="d1">9</data>
</edge>
<edge source="jackal" target="jackal" id="0">
  <data key="d0">promised to free the farmer</data>
  <data key="d1">11</data>
</edge>
<edge source="jackal" target="jackal" id="1">
  <data key="d0">gave advice to the farmer</data>
  <data key="d1">13</data>
</edge>
<edge source="jackal" target="jackal" id="2">
  <data key="d0">came down and said</data>
  <data key="d1">14</data>
</edge>
</graph></graphml>