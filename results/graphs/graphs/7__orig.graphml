  <data key="d0">overtaken by</data>
  <data key="d1">1</data>
</edge>
<edge source="old man" target="old man" id="1">
  <data key="d0">sought shelter in</data>
  <data key="d1">2</data>
</edge>
<edge source="old man" target="old man" id="2">
  <data key="d0">heard a sound of merriment</data>
  <data key="d1">3</data>
</edge>
<edge source="old man" target="old man" id="3">
  <data key="d0">offered to show his skill as a dancer</data>
  <data key="d1">8</data>
</edge>
<edge source="old man" target="demons" id="0">
  <data key="d0">began to laugh at</data>
  <data key="d1">5</data>
</edge>
<edge source="demons" target="demons" id="0">
  <data key="d0">dancing and singing and drinking</data>
  <data key="d1">4</data>
</edge>
<edge source="demons" target="demons" id="1">
  <data key="d0">congratulated him on his performance and asked for more dances</data>
  <data key="d1">9</data>
</edge>
<edge source="demons" target="demons" id="2">
  <data key="d0">vanished leaving him with his face smooth and free of the wen</data>
  <data key="d1">11</data>
</edge>
<edge source="demon" target="demon" id="0">
  <data key="d0">dancing by himself</data>
