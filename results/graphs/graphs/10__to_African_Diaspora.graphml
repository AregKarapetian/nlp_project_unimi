<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d1" for="edge" attr.name="order" attr.type="long" />
  <key id="d0" for="edge" attr.name="relation" attr.type="string" />
  <graph edgedefault="directed">
    <node id="mother" />
    <node id="chonguita" />
    <node id="akua" />
    <node id="their mother" />
    <node id="first door" />
    <node id="second door" />
    <node id="third door" />
    <node id="madonna" />
    <edge source="mother" target="mother" id="0">
      <data key="d0">lived with</data>
      <data key="d1">1</data>
    </edge>
    <edge source="mother" target="chonguita" id="0">
      <data key="d0">sent her daughter</data>
      <data key="d1">2</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="0">
      <data key="d0">went to draw water</data>
      <data key="d1">4</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="1">
      <data key="d0">found a passage</data>
      <data key="d1">5</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="2">
      <data key="d0">found treasures instead of dirt</data>
      <data key="d1">10</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="3">
      <data key="d0">chose the calico dress</data>
      <data key="d1">13</data>
    </edge>
    <edge source="chonguita" target="first door" id="0">
      <data key="d0">knocked on the door</data>
      <data key="d1">6</data>
    </edge>
    <edge source="chonguita" target="second door" id="0">
      <data key="d0">knocked on the second door</data>
      <data key="d1">7</data>
    </edge>
    <edge source="chonguita" target="third door" id="0">
      <data key="d0">knocked on the third door</data>
      <data key="d1">8</data>
    </edge>
    <edge source="chonguita" target="madonna" id="0">
      <data key="d0">replied to the madonna</data>
      <data key="d1">11</data>
    </edge>
    <edge source="akua" target="their mother" id="0">
      <data key="d0">refused to obey</data>
      <data key="d1">3</data>
    </edge>
    <edge source="akua" target="akua" id="0">
      <data key="d0">let the bucket fall down the well</data>
      <data key="d1">14</data>
    </edge>
    <edge source="madonna" target="madonna" id="0">
      <data key="d0">asked chonguita to take care of her son</data>
      <data key="d1">9</data>
    </edge>
    <edge source="madonna" target="madonna" id="1">
      <data key="d0">gave chonguita a choice of dresses</data>
      <data key="d1">12</data>
    </edge>
  </graph>
</graphml>
