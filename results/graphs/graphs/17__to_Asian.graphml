<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d1" for="edge" attr.name="order" attr.type="long"/>
<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="lion"/>
<node id="horse"/>
<node id="they"/>
<node id="fox"/>
<edge source="lion" target="lion" id="0">
  <data key="d0">found himself trapped</data>
  <data key="d1">1</data>
</edge>
<edge source="lion" target="lion" id="1">
  <data key="d0">promised to spare the horse's life</data>
  <data key="d1">4</data>
</edge>
<edge source="lion" target="lion" id="2">
  <data key="d0">pushed and squeezed himself back in</data>
  <data key="d1">10</data>
</edge>
<edge source="lion" target="lion" id="3">
  <data key="d0">became more wedged in</data>
  <data key="d1">11</data>
</edge>
<edge source="lion" target="horse" id="0">
  <data key="d0">snarled he'll make a meal of you</data>
  <data key="d1">6</data>
</edge>
<edge source="horse" target="horse" id="0">
  <data key="d0">overheard the lion's cries for help</data>
  <data key="d1">2</data>
</edge>
<edge source="horse" target="horse" id="1">
  <data key="d0">said he'll do that</data>
  <data key="d1">3</data>
</edge>
<edge source="horse" target="horse" id="2">
  <data key="d0">retorted what about our agreement</data>
  <data key="d1">7</data>
</edge>
<edge source="horse" target="lion" id="0">
  <data key="d0">dislodged the rocks and set free</data>
  <data key="d1">5</data>
</edge>
<edge source="horse" target="lion" id="1">
  <data key="d0">began hurling stones at the lion</data>
  <data key="d1">13</data>
</edge>
<edge source="they" target="they" id="0">
  <data key="d0">chose the fox as arbiter</data>
  <data key="d1">8</data>
</edge>
<edge source="fox" target="fox" id="0">
  <data key="d0">instructed them to return to rocky cleft</data>
  <data key="d1">9</data>
</edge>
<edge source="fox" target="fox" id="1">
  <data key="d0">declared now you are exactly where you were before</data>
  <data key="d1">12</data>
</edge>
<edge source="fox" target="fox" id="2">
  <data key="d0">smiled knowing justice had been served</data>
  <data key="d1">14</data>
</edge>
</graph></graphml>