<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d1" for="edge" attr.name="order" attr.type="long" />
  <key id="d0" for="edge" attr.name="relation" attr.type="string" />
  <graph edgedefault="directed">
    <node id="king" />
    <node id="three brothers" />
    <node id="don juan" />
    <node id="archbishop of the monkeys" />
    <node id="chonguita" />
    <node id="don pedro and don diego" />
    <node id="embroidered coats" />
    <node id="cap" />
    <edge source="king" target="king" id="0">
      <data key="d0">ordered his sons</data>
      <data key="d1">1</data>
    </edge>
    <edge source="king" target="king" id="1">
      <data key="d0">fainted upon learning</data>
      <data key="d1">9</data>
    </edge>
    <edge source="king" target="embroidered coats" id="0">
      <data key="d0">ordered each couple to make</data>
      <data key="d1">10</data>
    </edge>
    <edge source="king" target="cap" id="0">
      <data key="d0">ordered his daughters-in-law to make</data>
      <data key="d1">12</data>
    </edge>
    <edge source="three brothers" target="three brothers" id="0">
      <data key="d0">took different directions</data>
      <data key="d1">2</data>
    </edge>
    <edge source="don juan" target="don juan" id="0">
      <data key="d0">met an old man</data>
      <data key="d1">3</data>
    </edge>
    <edge source="don juan" target="don juan" id="1">
      <data key="d0">entered the palace</data>
      <data key="d1">4</data>
    </edge>
    <edge source="don juan" target="don juan" id="2">
      <data key="d0">met his brothers</data>
      <data key="d1">7</data>
    </edge>
    <edge source="don juan" target="chonguita" id="0">
      <data key="d0">asked permission to leave</data>
      <data key="d1">6</data>
    </edge>
    <edge source="don juan" target="chonguita" id="1">
      <data key="d0">hurled chonguita against the wall</data>
      <data key="d1">14</data>
    </edge>
    <edge source="archbishop of the monkeys" target="archbishop of the monkeys" id="0">
      <data key="d0">married don juan and chonguita</data>
      <data key="d1">5</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="0">
      <data key="d0">made the prettiest embroidered coat</data>
      <data key="d1">11</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="1">
      <data key="d0">made the most beautiful cap</data>
      <data key="d1">13</data>
    </edge>
    <edge source="don pedro and don diego" target="don juan" id="0">
      <data key="d0">teased their brother</data>
      <data key="d1">8</data>
    </edge>
  </graph>
</graphml>
