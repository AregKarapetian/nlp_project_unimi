  <data key="d0">ordered his sons</data>
  <data key="d1">1</data>
</edge>
<edge source="king" target="king" id="1">
  <data key="d0">fainted upon learning the news</data>
  <data key="d1">10</data>
</edge>
<edge source="king" target="king" id="2">
  <data key="d0">assigned houses for each couple to live in</data>
  <data key="d1">11</data>
</edge>
<edge source="king" target="king" id="3">
  <data key="d0">ordered his daughters-in-law to make him an embroidered coat</data>
  <data key="d1">12</data>
</edge>
<edge source="king" target="king" id="4">
  <data key="d0">ordered his daughters-in-law to embroider a cap for him</data>
  <data key="d1">14</data>
</edge>
<edge source="three brothers" target="three brothers" id="0">
  <data key="d0">took different directions</data>
  <data key="d1">2</data>
</edge>
<edge source="don juan" target="don juan" id="0">
  <data key="d0">met an old man</data>
  <data key="d1">3</data>
</edge>
<edge source="don juan" target="don juan" id="1">
  <data key="d0">entered the palace</data>
  <data key="d1">4</data>
</edge>
<edge source="don juan" target="don juan" id="2">
  <data key="d0">was greeted by a big monkey</data>
  <data key="d1">5</data>
</edge>
<edge source="don juan" target="don juan" id="3">
  <data key="d0">was married to chonguita</data>
  <data key="d1">7</data>
</edge>
<edge source="don juan" target="don juan" id="4">
  <data key="d0">met his brothers and their wives</data>
  <data key="d1">8</data>
</edge>
<edge source="big monkey" target="big monkey" id="0">
  <data key="d0">told don juan he would marry chonguita</data>
  <data key="d1">6</data>
</edge>
<edge source="king's sons" target="king's sons" id="0">
  <data key="d0">were surprised to see a monkey as don juan's wife</data>
  <data key="d1">9</data>
</edge>
<edge source="chonguita" target="chonguita" id="0">
  <data key="d0">surprised everyone by creating the most beautiful coat among them</data>
