<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d1" for="edge" attr.name="order" attr.type="long" />
  <key id="d0" for="edge" attr.name="relation" attr.type="string" />
  <graph edgedefault="directed">
    <node id="king alfonso" />
    <node id="king" />
    <node id="king's sons" />
    <node id="don juan" />
    <node id="archbishop of the monkeys" />
    <node id="chonguita" />
    <node id="chonguita's mother" />
    <edge source="king alfonso" target="king alfonso" id="0">
      <data key="d0">ruled the kingdom</data>
      <data key="d1">1</data>
    </edge>
    <edge source="king" target="king" id="0">
      <data key="d0">had three sons</data>
      <data key="d1">2</data>
    </edge>
    <edge source="king" target="king" id="1">
      <data key="d0">summoned his sons</data>
      <data key="d1">3</data>
    </edge>
    <edge source="king" target="king" id="2">
      <data key="d0">fainted from shock upon learning of his youngest son's union with a monkey</data>
      <data key="d1">10</data>
    </edge>
    <edge source="king's sons" target="king's sons" id="0">
      <data key="d0">agreed on a meeting place</data>
      <data key="d1">4</data>
    </edge>
    <edge source="don juan" target="don juan" id="0">
      <data key="d0">met an old man</data>
      <data key="d1">5</data>
    </edge>
    <edge source="don juan" target="don juan" id="1">
      <data key="d0">entered the palace</data>
      <data key="d1">6</data>
    </edge>
    <edge source="don juan" target="chonguita" id="0">
      <data key="d0">requested permission from his wife</data>
      <data key="d1">8</data>
    </edge>
    <edge source="archbishop of the monkeys" target="archbishop of the monkeys" id="0">
      <data key="d0">united don juan and chonguita in matrimony</data>
      <data key="d1">7</data>
    </edge>
    <edge source="chonguita's mother" target="chonguita's mother" id="0">
      <data key="d0">insisted that her daughter accompany don juan</data>
      <data key="d1">9</data>
    </edge>
  </graph>
</graphml>
