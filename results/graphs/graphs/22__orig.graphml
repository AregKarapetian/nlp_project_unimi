<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d1" for="edge" attr.name="order" attr.type="long"/>
<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="parents"/>
<node id="prince"/>
<node id="maid"/>
<node id="her"/>
<node id="second woman"/>
<node id="sheet"/>
<node id="third woman"/>
<edge source="parents" target="parents" id="0">
  <data key="d0">wanted him to marry</data>
  <data key="d1">1</data>
</edge>
<edge source="parents" target="parents" id="1">
  <data key="d0">told the prince to go find her</data>
  <data key="d1">3</data>
</edge>
<edge source="prince" target="prince" id="0">
  <data key="d0">said he would marry only a woman</data>
  <data key="d1">2</data>
</edge>
<edge source="prince" target="prince" id="1">
  <data key="d0">went forth and came to a woman</data>
  <data key="d1">4</data>
</edge>
<edge source="prince" target="prince" id="2">
  <data key="d0">asked what was the matter with her</data>
  <data key="d1">5</data>
</edge>
<edge source="prince" target="prince" id="3">
  <data key="d0">thought she wasn't the right one</data>
  <data key="d1">7</data>
</edge>
<edge source="prince" target="prince" id="4">
  <data key="d0">went on his way and found another woman</data>
  <data key="d1">8</data>
</edge>
<edge source="prince" target="prince" id="5">
  <data key="d0">asked what was the matter with her</data>
  <data key="d1">10</data>
</edge>
<edge source="prince" target="prince" id="6">
  <data key="d0">thought she wasn't the most sensitive one</data>
  <data key="d1">12</data>
</edge>
<edge source="prince" target="prince" id="7">
  <data key="d0">continued on his way and came to a third woman</data>
  <data key="d1">13</data>
</edge>
<edge source="maid" target="her" id="0">
  <data key="d0">pulled out one of her hairs</data>
  <data key="d1">6</data>
</edge>
<edge source="second woman" target="second woman" id="0">
  <data key="d0">was wrapped in fine linen</data>
  <data key="d1">9</data>
</edge>
<edge source="sheet" target="her" id="0">
  <data key="d0">made her sick</data>
  <data key="d1">11</data>
</edge>
<edge source="third woman" target="third woman" id="0">
  <data key="d0">was sitting in an easy chair</data>
  <data key="d1">14</data>
</edge>
</graph></graphml>