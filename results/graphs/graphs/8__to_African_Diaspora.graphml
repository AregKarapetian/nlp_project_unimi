<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d1" for="edge" attr.name="order" attr.type="long"/>
<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="traveler"/>
<node id="night air"/>
<node id="group of forest dwellers"/>
<node id="elves"/>
<node id="wen"/>
<node id="neighbor"/>
<edge source="traveler" target="traveler" id="0">
  <data key="d0">found himself lost</data>
  <data key="d1">1</data>
</edge>
<edge source="traveler" target="traveler" id="1">
  <data key="d0">stumbled upon a hollow tree</data>
  <data key="d1">2</data>
</edge>
<edge source="traveler" target="traveler" id="2">
  <data key="d0">watched with trepidation as the elves' revelry continued</data>
  <data key="d1">5</data>
</edge>
<edge source="traveler" target="traveler" id="3">
  <data key="d0">was sharing tales of his adventure with friends and family</data>
  <data key="d1">9</data>
</edge>
<edge source="night air" target="night air" id="0">
  <data key="d0">was heavy with the scent of blooming flowers</data>
  <data key="d1">3</data>
</edge>
<edge source="group of forest dwellers" target="group of forest dwellers" id="0">
  <data key="d0">had gathered at the tree's base</data>
  <data key="d1">4</data>
</edge>
<edge source="elves" target="elves" id="0">
  <data key="d0">welcomed the traveler with open arms</data>
  <data key="d1">6</data>
</edge>
<edge source="elves" target="elves" id="1">
  <data key="d0">bid the traveler farewell</data>
  <data key="d1">7</data>
</edge>
<edge source="elves" target="wen" id="0">
  <data key="d0">took something precious from the traveler as collateral</data>
  <data key="d1">8</data>
</edge>
<edge source="elves" target="wen" id="1">
  <data key="d0">returned the pawned wen to the neighbor</data>
  <data key="d1">12</data>
</edge>
<edge source="elves" target="traveler" id="0">
  <data key="d0">stuck it onto his forehead alongside the one he already had</data>
  <data key="d1">13</data>
</edge>
<edge source="neighbor" target="neighbor" id="0">
  <data key="d0">saw an opportunity to replicate the traveler's experience</data>
  <data key="d1">10</data>
</edge>
<edge source="neighbor" target="neighbor" id="1">
  <data key="d0">set out to find the hollow tree</data>
  <data key="d1">11</data>
</edge>
</graph></graphml>