<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="farmer"/>
<node id="wind"/>
<node id="husband"/>
<node id="wife"/>
<node id="they"/>
<node id="wild beast"/>
<node id="their store"/>
<node id="creature"/>
<node id="barber"/>
