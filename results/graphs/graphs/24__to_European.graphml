<node id="with a shave"/>
<node id="his face"/>
<node id="she"/>
<node id="him"/>
<edge source="farmer" target="farmer" id="0">
  <data key="d0">sat by the fire</data>
  <data key="d1">1</data>
</edge>
<edge source="wind" target="wind" id="0">
  <data key="d0">blew open the door</data>
  <data key="d1">2</data>
</edge>
<edge source="husband" target="husband" id="0">
  <data key="d0">proposed a wager</data>
  <data key="d1">3</data>
</edge>
<edge source="wife" target="wife" id="0">
  <data key="d0">agreed to arrangement</data>
  <data key="d1">4</data>
</edge>
<edge source="wife" target="wife" id="1">
  <data key="d0">beheld her husband</data>
  <data key="d1">13</data>
</edge>
<edge source="they" target="they" id="0">
  <data key="d0">lay abed</data>
  <data key="d1">5</data>
</edge>
<edge source="wild beast" target="their store" id="0">
  <data key="d0">rummaged through provisions</data>
  <data key="d1">6</data>
</edge>
<edge source="creature" target="creature" id="0">
  <data key="d0">departed suddenly</data>
  <data key="d1">7</data>
</edge>
<edge source="barber" target="in the house" id="0">
  <data key="d0">chanced upon the farmer</data>
  <data key="d1">8</data>
</edge>
<edge source="barber" target="with a shave" id="0">
  <data key="d0">attempted to rouse him</data>
  <data key="d1">10</data>
</edge>
<edge source="barber" target="his face" id="0">
  <data key="d0">shaved off half beard</data>
  <data key="d1">11</data>
</edge>
<edge source="barber" target="barber" id="0">
  <data key="d0">cried out bewitched</data>
  <data key="d1">12</data>
</edge>
<edge source="man" target="man" id="0">
  <data key="d0">remained mute</data>
  <data key="d1">9</data>
</edge>
<edge source="she" target="him" id="0">
  <data key="d0">exclaimed in sorrow</data>
