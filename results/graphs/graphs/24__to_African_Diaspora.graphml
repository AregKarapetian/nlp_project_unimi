<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d1" for="edge" attr.name="order" attr.type="long"/>
<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="farmer"/>
<node id="wife"/>
<node id="wild dog"/>
<node id="woman"/>
<node id="barber"/>
<edge source="farmer" target="farmer" id="0">
  <data key="d0">sat by the fire</data>
  <data key="d1">1</data>
</edge>
<edge source="farmer" target="farmer" id="1">
  <data key="d0">said who speaks first gets to close it</data>
  <data key="d1">3</data>
</edge>
<edge source="farmer" target="wife" id="0">
  <data key="d0">said you spoke first</data>
  <data key="d1">11</data>
</edge>
<edge source="farmer" target="wife" id="1">
  <data key="d0">ordered her to begone and shut the door</data>
  <data key="d1">12</data>
</edge>
<edge source="wife" target="wife" id="0">
  <data key="d0">bickered over who should shut the door</data>
  <data key="d1">2</data>
</edge>
<edge source="wife" target="wife" id="1">
  <data key="d0">retorted she will not be silenced</data>
  <data key="d1">4</data>
</edge>
<edge source="wife" target="wife" id="2">
  <data key="d0">saw her husband transformed</data>
  <data key="d1">9</data>
</edge>
<edge source="wife" target="wife" id="3">
  <data key="d0">cried out in fear</data>
  <data key="d1">10</data>
</edge>
<edge source="wild dog" target="wild dog" id="0">
  <data key="d0">devoured the family's food</data>
  <data key="d1">5</data>
</edge>
<edge source="woman" target="woman" id="0">
  <data key="d0">set out to grind grain</data>
  <data key="d1">6</data>
</edge>
<edge source="barber" target="barber" id="0">
  <data key="d0">chanced upon the farmer</data>
  <data key="d1">7</data>
</edge>
<edge source="barber" target="farmer" id="0">
  <data key="d0">shaved off half the farmer's beard and mustache</data>
  <data key="d1">8</data>
</edge>
</graph></graphml>