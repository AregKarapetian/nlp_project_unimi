<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d1" for="edge" attr.name="order" attr.type="long" />
  <key id="d0" for="edge" attr.name="relation" attr.type="string" />
  <graph edgedefault="directed">
    <node id="old crone" />
    <node id="crone" />
    <node id="chonguita" />
    <node id="chonguita's mother" />
    <node id="sprite" />
    <node id="oak tree" />
    <node id="woodsman" />
    <edge source="old crone" target="old crone" id="0">
      <data key="d0">lived in village</data>
      <data key="d1">1</data>
    </edge>
    <edge source="crone" target="chonguita" id="0">
      <data key="d0">beckoned young maiden</data>
      <data key="d1">2</data>
    </edge>
    <edge source="crone" target="chonguita" id="1">
      <data key="d0">offered basket of apples</data>
      <data key="d1">4</data>
    </edge>
    <edge source="crone" target="chonguita" id="2">
      <data key="d0">filled table with food</data>
      <data key="d1">6</data>
    </edge>
    <edge source="crone" target="crone" id="0">
      <data key="d0">pressed on through river</data>
      <data key="d1">12</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="0">
      <data key="d0">entered the room</data>
      <data key="d1">3</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="1">
      <data key="d0">agreed to stay with crone</data>
      <data key="d1">7</data>
    </edge>
    <edge source="chonguita" target="chonguita" id="2">
      <data key="d0">dropped the comb</data>
      <data key="d1">10</data>
    </edge>
    <edge source="chonguita's mother" target="chonguita's mother" id="0">
      <data key="d0">entrusted errand to chonguita</data>
      <data key="d1">5</data>
    </edge>
    <edge source="sprite" target="chonguita" id="0">
      <data key="d0">warned chonguita of harm</data>
      <data key="d1">8</data>
    </edge>
    <edge source="sprite" target="chonguita" id="1">
      <data key="d0">left comb and handkerchief</data>
      <data key="d1">9</data>
    </edge>
    <edge source="oak tree" target="oak tree" id="0">
      <data key="d0">sprouted forth from earth</data>
      <data key="d1">11</data>
    </edge>
    <edge source="woodsman" target="crone" id="0">
      <data key="d0">struck off the crone's head</data>
      <data key="d1">13</data>
    </edge>
    <edge source="woodsman" target="chonguita" id="0">
      <data key="d0">escorted chonguita back home</data>
      <data key="d1">14</data>
    </edge>
  </graph>
</graphml>
