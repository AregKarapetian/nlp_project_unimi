<edge source="mei's mother" target="mei's mother" id="0">
  <data key="d0">instructed mei to draw water from the well</data>
  <data key="d1">1</data>
</edge>
<edge source="mei's sister" target="mei's sister" id="0">
  <data key="d0">refused to help mei</data>
  <data key="d1">2</data>
</edge>
<edge source="mei's sister" target="mei's sister" id="1">
  <data key="d0">descended into the well and met the same doors as mei</data>
  <data key="d1">14</data>
</edge>
<edge source="mei" target="mei" id="0">
  <data key="d0">climbed down into the well</data>
  <data key="d1">3</data>
</edge>
<edge source="mei" target="mei" id="1">
  <data key="d0">met the benevolent bodhisattva</data>
  <data key="d1">6</data>
</edge>
<edge source="mei" target="mei" id="2">
  <data key="d0">completed tasks</data>
  <data key="d1">8</data>
</edge>
<edge source="mei" target="mei" id="3">
  <data key="d0">returned home</data>
  <data key="d1">12</data>
</edge>
<edge source="wise old sage" target="wise old sage" id="0">
  <data key="d0">had not found a cord and bucket</data>
  <data key="d1">4</data>
</edge>
<edge source="mischievous spirit" target="mischievous spirit" id="0">
  <data key="d0">claimed to have not found the cord and bucket</data>
  <data key="d1">5</data>
</edge>
<edge source="bodhisattva" target="bodhisattva" id="0">
  <data key="d0">instructed mei to care for her son and sweep the house</data>
  <data key="d1">7</data>
</edge>
<edge source="bodhisattva" target="bodhisattva" id="1">
  <data key="d0">gave mei a silk dress</data>
  <data key="d1">9</data>
</edge>
<edge source="bodhisattva" target="bodhisattva" id="2">
  <data key="d0">returned mei's bucket and cord</data>
  <data key="d1">10</data>
</edge>
<edge source="brilliant star" target="brilliant star" id="0">
  <data key="d0">descended upon mei's brow</data>
  <data key="d1">11</data>
</edge>
<edge source="bodhisattva's blessing" target="bodhisattva's blessing" id="0">
  <data key="d0">was revealed to mei's family</data>
  <data key="d1">13</data>
</edge>
</graph></graphml>