<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d1" for="edge" attr.name="order" attr.type="long"/>
<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="br'er rabbit"/>
<node id="mr. hawk"/>
<edge source="br'er rabbit" target="br'er rabbit" id="0">
  <data key="d0">strolled along</data>
  <data key="d1">1</data>
</edge>
<edge source="br'er rabbit" target="br'er rabbit" id="1">
  <data key="d0">noticed a shadow</data>
  <data key="d1">2</data>
</edge>
<edge source="br'er rabbit" target="br'er rabbit" id="2">
  <data key="d0">cried out for mercy</data>
  <data key="d1">5</data>
</edge>
<edge source="br'er rabbit" target="br'er rabbit" id="3">
  <data key="d0">lay still and pondered</data>
  <data key="d1">6</data>
</edge>
<edge source="br'er rabbit" target="br'er rabbit" id="4">
  <data key="d0">suggested that he would make a poor meal</data>
  <data key="d1">7</data>
</edge>
<edge source="br'er rabbit" target="br'er rabbit" id="5">
  <data key="d0">proposed waiting for mr. hawk to calm down or grow larger</data>
  <data key="d1">9</data>
</edge>
<edge source="br'er rabbit" target="br'er rabbit" id="6">
  <data key="d0">had no intention of growing larger or keeping his promise</data>
  <data key="d1">11</data>
</edge>
<edge source="br'er rabbit" target="br'er rabbit" id="7">
  <data key="d0">waited until mr. hawk let his guard down before making his escape</data>
  <data key="d1">12</data>
</edge>
<edge source="mr. hawk" target="br'er rabbit" id="0">
  <data key="d0">swooped down and snatched</data>
  <data key="d1">3</data>
</edge>
<edge source="mr. hawk" target="br'er rabbit" id="1">
  <data key="d0">ensnared br'er rabbit in his grip</data>
  <data key="d1">4</data>
</edge>
<edge source="mr. hawk" target="mr. hawk" id="0">
  <data key="d0">narrowed his eyes at the suggestion</data>
  <data key="d1">8</data>
</edge>
<edge source="mr. hawk" target="mr. hawk" id="1">
  <data key="d0">was swayed by br'er rabbit's arguments and agreed to wait</data>
  <data key="d1">10</data>
</edge>
<edge source="mr. hawk" target="mr. hawk" id="2">
  <data key="d0">was forced to admit defeat once again</data>
  <data key="d1">13</data>
</edge>
</graph></graphml>