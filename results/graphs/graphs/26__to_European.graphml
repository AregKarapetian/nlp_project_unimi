<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d1" for="edge" attr.name="order" attr.type="long"/>
<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="drought"/>
<node id="assembly"/>
<node id="one of the creatures"/>
<node id="earth"/>
<node id="rabbit"/>
<node id="old tortoise"/>
<node id="tortoise"/>
<node id="lion"/>
<edge source="drought" target="drought" id="0">
  <data key="d0">had beset</data>
  <data key="d1">1</data>
</edge>
<edge source="assembly" target="assembly" id="0">
  <data key="d0">was convened</data>
  <data key="d1">2</data>
</edge>
<edge source="assembly" target="assembly" id="1">
  <data key="d0">agreed to dance</data>
  <data key="d1">4</data>
</edge>
<edge source="assembly" target="assembly" id="2">
  <data key="d0">discovered rabbit's footprints</data>
  <data key="d1">7</data>
</edge>
<edge source="assembly" target="assembly" id="3">
  <data key="d0">deliberated seeking a suitable punishment for rabbit's transgressions</data>
  <data key="d1">11</data>
</edge>
<edge source="one of the creatures" target="one of the creatures" id="0">
  <data key="d0">suggested dancing</data>
  <data key="d1">3</data>
</edge>
<edge source="earth" target="earth" id="0">
  <data key="d0">trembled and water began to rise</data>
  <data key="d1">5</data>
</edge>
<edge source="rabbit" target="rabbit" id="0">
  <data key="d0">refused to join in the dance but later quenched his thirst</data>
  <data key="d1">6</data>
</edge>
<edge source="rabbit" target="rabbit" id="1">
  <data key="d0">proposed being taken by his tail and dashed against a stone</data>
  <data key="d1">12</data>
</edge>
<edge source="rabbit" target="tortoise" id="0">
  <data key="d0">trod upon tortoise</data>
  <data key="d1">9</data>
</edge>
<edge source="old tortoise" target="old tortoise" id="0">
  <data key="d0">suggested catching the wily rabbit</data>
  <data key="d1">8</data>
</edge>
<edge source="tortoise" target="tortoise" id="0">
  <data key="d0">slowly turned himself around and began to make his way back</data>
  <data key="d1">10</data>
</edge>
<edge source="lion" target="rabbit" id="0">
  <data key="d0">was chosen to carry out the sentence but as he swung rabbit around</data>
  <data key="d1">13</data>
</edge>
</graph></graphml>