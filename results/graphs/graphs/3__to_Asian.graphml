<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d1" for="edge" attr.name="order" attr.type="long" />
  <key id="d0" for="edge" attr.name="relation" attr.type="string" />
  <graph edgedefault="directed">
    <node id="kaito" />
    <node id="seashore" />
    <node id="kite" />
    <node id="mouse" />
    <node id="kaito's wife" />
    <node id="young girl" />
    <node id="sun" />
    <node id="cloud" />
    <node id="wind" />
    <node id="mountain" />
    <edge source="kaito" target="seashore" id="0">
      <data key="d0">meditated on</data>
      <data key="d1">1</data>
    </edge>
    <edge source="kaito" target="mouse" id="0">
      <data key="d0">picked up</data>
      <data key="d1">4</data>
    </edge>
    <edge source="kaito" target="mouse" id="1">
      <data key="d0">prayed to transform</data>
      <data key="d1">5</data>
    </edge>
    <edge source="kaito" target="kaito" id="0">
      <data key="d0">said it was time for her to marry</data>
      <data key="d1">8</data>
    </edge>
    <edge source="kaito" target="kaito" id="1">
      <data key="d0">sought out the sun as suitor</data>
      <data key="d1">10</data>
    </edge>
    <edge source="kite" target="kite" id="0">
      <data key="d0">flew by with</data>
      <data key="d1">2</data>
    </edge>
    <edge source="mouse" target="mouse" id="0">
      <data key="d0">fell from sky</data>
      <data key="d1">3</data>
    </edge>
    <edge source="mouse" target="mouse" id="1">
      <data key="d0">was transformed into</data>
      <data key="d1">6</data>
    </edge>
    <edge source="kaito's wife" target="young girl" id="0">
      <data key="d0">welcomed and treated as own</data>
      <data key="d1">7</data>
    </edge>
    <edge source="young girl" target="young girl" id="0">
      <data key="d0">desired a powerful husband</data>
      <data key="d1">9</data>
    </edge>
    <edge source="sun" target="sun" id="0">
      <data key="d0">recommended cloud as suitor</data>
      <data key="d1">11</data>
    </edge>
    <edge source="cloud" target="cloud" id="0">
      <data key="d0">recommended wind as suitor</data>
      <data key="d1">12</data>
    </edge>
    <edge source="wind" target="wind" id="0">
      <data key="d0">recommended mountain as suitor</data>
      <data key="d1">13</data>
    </edge>
    <edge source="mountain" target="mountain" id="0">
      <data key="d0">recommended rat as suitor</data>
      <data key="d1">14</data>
    </edge>
  </graph>
</graphml>
