<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d1" for="edge" attr.name="order" attr.type="long" />
  <key id="d0" for="edge" attr.name="relation" attr.type="string" />
  <graph edgedefault="directed">
    <node id="vessel" />
    <node id="batteries" />
    <node id="ship" />
    <node id="dutchman" />
    <node id="ships" />
    <node id="hms leven" />
    <node id="barracouta" />
    <node id="capt owen" />
    <node id="leven" />
    <node id="her log" />
    <node id="veteran sailor" />
    <node id="passenger" />
    <node id="we" />
    <edge source="vessel" target="vessel" id="0">
      <data key="d0">entering table bay</data>
      <data key="d1">1</data>
    </edge>
    <edge source="vessel" target="vessel" id="1">
      <data key="d0">continuing to beat about</data>
      <data key="d1">3</data>
    </edge>
    <edge source="batteries" target="ship" id="0">
      <data key="d0">fired on the distressed ship</data>
      <data key="d1">2</data>
    </edge>
    <edge source="dutchman" target="ships" id="0">
      <data key="d0">appearing to ships</data>
      <data key="d1">4</data>
    </edge>
    <edge source="hms leven" target="barracouta" id="0">
      <data key="d0">saw her consort</data>
      <data key="d1">5</data>
    </edge>
    <edge source="barracouta" target="barracouta" id="0">
      <data key="d0">left no doubt as to her identity</data>
      <data key="d1">6</data>
    </edge>
    <edge source="barracouta" target="her log" id="0">
      <data key="d0">seen by her log</data>
      <data key="d1">9</data>
    </edge>
    <edge source="capt owen" target="barracouta" id="0">
      <data key="d0">attempted to close with the barracouta</data>
      <data key="d1">7</data>
    </edge>
    <edge source="leven" target="leven" id="0">
      <data key="d0">anchored in simon's bay</data>
      <data key="d1">8</data>
    </edge>
    <edge source="leven" target="leven" id="1">
      <data key="d0">witnessed another similar phenomenon</data>
      <data key="d1">10</data>
    </edge>
    <edge source="veteran sailor" target="dutchman" id="0">
      <data key="d0">not caught by the dutchman</data>
      <data key="d1">11</data>
    </edge>
    <edge source="passenger" target="passenger" id="0">
      <data key="d0">saw a vessel in nearly similar circumstances</data>
      <data key="d1">12</data>
    </edge>
    <edge source="we" target="we" id="0">
      <data key="d0">hoisted lights over the gangway</data>
      <data key="d1">13</data>
    </edge>
  </graph>
</graphml>
