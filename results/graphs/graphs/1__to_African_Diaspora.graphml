<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d1" for="edge" attr.name="order" attr.type="long"/>
<key id="d0" for="edge" attr.name="relation" attr.type="string"/>
<graph edgedefault="directed"><node id="king"/>
<node id="three brothers"/>
<node id="don juan"/>
<node id="archbishop of the monkeys"/>
<node id="chonguita"/>
<edge source="king" target="king" id="0">
  <data key="d0">lived in the village of</data>
  <data key="d1">1</data>
</edge>
<edge source="king" target="king" id="1">
  <data key="d0">called his sons to him and said they should go forth from their kingdom to seek their fortunes</data>
  <data key="d1">2</data>
</edge>
<edge source="king" target="king" id="2">
  <data key="d0">learned of his sons marriage to a monkey and was taken aback but said he would bear it with patience</data>
  <data key="d1">9</data>
</edge>
<edge source="king" target="king" id="3">
  <data key="d0">assigned a house to each couple and ordered them to make him an embroidered coat within three days</data>
  <data key="d1">10</data>
</edge>
<edge source="king" target="king" id="4">
  <data key="d0">issued another challenge to embroider a cap for him within two days under penalty of death</data>
  <data key="d1">12</data>
</edge>
<edge source="three brothers" target="three brothers" id="0">
  <data key="d0">set out on their journey each taking a different path but agreed to meet in a certain place deep within the forest</data>
  <data key="d1">3</data>
</edge>
<edge source="don juan" target="don juan" id="0">
  <data key="d0">came upon an old man sitting by the side of the road who offered him bread and warned him to divide it among the monkeys guarding the palace gate</data>
  <data key="d1">4</data>
</edge>
<edge source="don juan" target="don juan" id="1">
  <data key="d0">followed the old mans instructions and entered the palace where a large monkey approached him and spoke in a gentle voice saying he would marry don juans daughter chonguita</data>
  <data key="d1">5</data>
</edge>
<edge source="don juan" target="don juan" id="2">
  <data key="d0">asked permission from his wife to visit the place where he and his brothers had agreed to meet accompanied by chonguita</data>
  <data key="d1">7</data>
</edge>
<edge source="don juan" target="don juan" id="3">
  <data key="d0">arrived at the meeting place his brothers were surprised to see him with a monkey as his companion</data>
  <data key="d1">8</data>
</edge>
<edge source="don juan" target="chonguita" id="0">
  <data key="d0">became angry with chonguita for insisting that he dance with her</data>
  <data key="d1">14</data>
</edge>
<edge source="archbishop of the monkeys" target="archbishop of the monkeys" id="0">
  <data key="d0">was summoned and don juan and chonguita were married without delay</data>
  <data key="d1">6</data>
</edge>
<edge source="chonguita" target="chonguita" id="0">
  <data key="d0">created the most beautiful coat of all surprising everyone including her husbands father</data>
  <data key="d1">11</data>
</edge>
<edge source="chonguita" target="chonguita" id="1">
  <data key="d0">again created the most exquisite work and her picture was by far the most beautiful among all the couples efforts</data>
  <data key="d1">13</data>
</edge>
</graph></graphml>