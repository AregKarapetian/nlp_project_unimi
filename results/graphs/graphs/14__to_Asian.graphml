  <data key="d0">responded with a growl</data>
  <data key="d1">11</data>
</edge>
<edge source="brer rabbit" target="brer rabbit" id="0">
  <data key="d0">grew weary from his journey</data>
  <data key="d1">3</data>
</edge>
<edge source="brer rabbit" target="brer rabbit" id="1">
  <data key="d0">noticed an unsettling stillness</data>
  <data key="d1">4</data>
